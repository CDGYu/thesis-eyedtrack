# Copy this file to `.env` and fill in the values. `.env` is gitignored, so real secrets
# stay out of version control. The backend auto-loads `.env` at startup (config_loader).

# MySQL password for the eyedtrack_app DB user (required for MySQL persistence).
# Without it the server still runs but logs to file only.
EYEDTRACK_DB_PASSWORD=

# Optional connection overrides — defaults come from config.yaml (integration.database):
# EYEDTRACK_DB_HOST=localhost
# EYEDTRACK_DB_PORT=3306
# EYEDTRACK_DB_NAME=eyedtrack_db
# EYEDTRACK_DB_USER=eyedtrack_app
